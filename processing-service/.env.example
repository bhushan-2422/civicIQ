# ─── Google Cloud Credentials ─────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCP_PROJECT_ID=your-gcp-project-id
FIRESTORE_DATABASE=(default)

# ─── Google Cloud Storage ─────────────────────────────────
GCS_BUCKET_NAME=your-gcs-bucket-name

# ─── Google Cloud Pub/Sub ─────────────────────────────────
PUBSUB_SUBSCRIPTION=complaint-created-sub

# ─── Google Gemini ────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── Google Maps Platform ─────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── Twilio ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ─── Duplicate Detection ─────────────────────────────────
DUPLICATE_RADIUS_METERS=500
DUPLICATE_DAYS=30

# ─── Priority Weights (must sum to 1.0) ──────────────────
PRIORITY_WEIGHT_SEVERITY=0.35
PRIORITY_WEIGHT_CRITICALITY=0.20
PRIORITY_WEIGHT_RECURRENCE=0.15
PRIORITY_WEIGHT_CREDIBILITY=0.15
PRIORITY_WEIGHT_VALIDATION=0.15
EQUITY_MULTIPLIER=1.0

# ─── Flask ───────────────────────────────────────────────
FLASK_ENV=development
FLASK_PORT=5001
